    {"id": "intense_all",  "args": ["-p-", "-T4", "-A", "-v"],             "name_key": "preset.intense_all.name",  "hint_key": "preset.intense_all.hint",  "needs_root": true,  "intrusive": false},
    {"id": "intense_udp",  "args": ["-sU", "-sS", "-T4", "-A", "-v"],      "name_key": "preset.intense_udp.name",  "hint_key": "preset.intense_udp.hint",  "needs_root": true,  "intrusive": false},
